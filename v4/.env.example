# ---- Chat model (gpt-oss-120b, served via an OpenAI-compatible endpoint) ----
SPARROW_LLM_BASE_URL=https://your-gpt-oss-endpoint/v1
SPARROW_LLM_API_KEY=replace-me
SPARROW_LLM_MODEL=gpt-oss-120b
SPARROW_REASONING_EFFORT=medium

# ---- Embeddings (OpenAI embedding model) ----
SPARROW_EMBEDDING_BASE_URL=https://api.openai.com/v1
SPARROW_EMBEDDING_API_KEY=replace-me
SPARROW_EMBEDDING_MODEL=text-embedding-3-small

# ---- Agent behaviour ----
SPARROW_MAX_AGENT_STEPS=12
SPARROW_RETRIEVAL_K=6
SPARROW_ENABLE_VERIFIER=true
SPARROW_ENABLE_SELF_CONSISTENCY=false
SPARROW_SELF_CONSISTENCY_SAMPLES=3
SPARROW_WORKSPACE_DIR=./.sparrow_workspace
